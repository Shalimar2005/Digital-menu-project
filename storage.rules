rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /dishes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        (request.auth.token.email == "kathadeshalimar@gmail.com" || 
         firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)));
    }
  }
}
